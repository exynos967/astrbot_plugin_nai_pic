{
  "model": {
    "type": "object",
    "description": "NovelAI Web 接口基础配置",
    "items": {
      "base_url": {
        "type": "string",
        "description": "NAI Web API 基础地址",
        "default": "https://std.loliyc.com",
        "obvious_hint": true
      },
      "api_key": {
        "type": "string",
        "description": "接口 Token，可留空",
        "default": ""
      },
      "nai_endpoint": {
        "type": "string",
        "description": "接口路径",
        "default": "/generate"
      },
      "default_model": {
        "type": "string",
        "description": "默认模型",
        "default": "nai-diffusion-4-5-full",
        "options": [
          "nai-diffusion-3",
          "nai-diffusion-3-furry",
          "nai-diffusion-4-full",
          "nai-diffusion-4-curated",
          "nai-diffusion-4-5-full"
        ]
      },
      "available_models": {
        "type": "list",
        "description": "允许切换的模型列表",
        "default": [
          "nai-diffusion-3",
          "nai-diffusion-3-furry",
          "nai-diffusion-4-full",
          "nai-diffusion-4-curated",
          "nai-diffusion-4-5-full"
        ]
      },
      "nai_size": {
        "type": "string",
        "description": "默认尺寸",
        "default": "832x1216"
      },
      "sampler": {
        "type": "string",
        "description": "采样器",
        "default": "k_euler_ancestral"
      },
      "num_inference_steps": {
        "type": "int",
        "description": "推理步数",
        "default": 28
      },
      "guidance_scale": {
        "type": "float",
        "description": "CFG / guidance scale",
        "default": 5.0
      },
      "negative_prompt_add": {
        "type": "text",
        "description": "附加负面提示词",
        "default": ""
      },
      "custom_prompt_add": {
        "type": "text",
        "description": "附加正面提示词，会拼到主 prompt 前面",
        "default": ""
      },
      "nai_extra_params": {
        "type": "text",
        "description": "额外请求参数，填写 JSON 对象字符串",
        "default": "{}",
        "editor_mode": true,
        "editor_language": "json"
      }
    }
  },
  "model_nai3": {
    "type": "object",
    "description": "NAI V3 专用配置",
    "items": {
      "nai_size": {
        "type": "string",
        "description": "V3 默认尺寸",
        "default": "832x1216"
      },
      "selfie_prompt_add": {
        "type": "text",
        "description": "自拍时补充的角色特征标签",
        "default": ""
      },
      "sampler": {
        "type": "string",
        "description": "V3 采样器",
        "default": "k_euler_ancestral"
      },
      "num_inference_steps": {
        "type": "int",
        "description": "V3 推理步数",
        "default": 28
      },
      "guidance_scale": {
        "type": "float",
        "description": "V3 guidance scale",
        "default": 5.0
      },
      "default_size": {
        "type": "string",
        "description": "V3 默认尺寸（当 nai_size 未设置时回退）",
        "default": "1024x1280"
      },
      "custom_prompt_add": {
        "type": "text",
        "description": "V3 附加正面提示词",
        "default": ""
      },
      "negative_prompt_add": {
        "type": "text",
        "description": "V3 附加负面提示词",
        "default": ""
      },
      "nai_cfg": {
        "type": "float",
        "description": "V3 cfg 参数",
        "default": 0.0
      },
      "nai_noise_schedule": {
        "type": "string",
        "description": "V3 噪声调度器",
        "default": "karras"
      },
      "nai_nocache": {
        "type": "int",
        "description": "V3 nocache 参数",
        "default": 0
      },
      "nai_extra_params": {
        "type": "text",
        "description": "V3 额外请求参数，填写 JSON 对象字符串",
        "default": "{}",
        "editor_mode": true,
        "editor_language": "json"
      },
      "artist_presets": {
        "type": "list",
        "description": "V3 画师预设列表，格式为 [{\"name\":\"风格名\",\"prompt\":\"artist:xxx\"}]",
        "default": []
      }
    }
  },
