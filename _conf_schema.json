{
  "model": {
    "type": "object",
    "description": "基础配置",
    "items": {
      "base_url": {
        "type": "string",
        "description": "NAI Web API 基础地址",
        "hint": "NovelAI 兼容的 Web API 基础地址，如自建反代则填写反代地址",
        "default": "https://std.loliyc.com",
        "obvious_hint": true
      },
      "api_key": {
        "type": "string",
        "description": "接口 Token",
        "hint": "部分 API 端点需要 Token 鉴权，不需要时可留空",
        "default": ""
      },
      "nai_endpoint": {
        "type": "string",
        "description": "接口路径",
        "hint": "API 基础地址后面的路径，默认 /generate，一般无需修改",
        "default": "/generate"
      },
      "default_model": {
        "type": "string",
        "description": "默认模型",
        "hint": "新会话默认使用的模型，用户可通过 /nai set 临时切换",
        "default": "nai-diffusion-4-5-full",
        "options": [
          "nai-diffusion-3",
          "nai-diffusion-3-furry",
          "nai-diffusion-4-full",
          "nai-diffusion-4-curated",
          "nai-diffusion-4-5-full"
        ]
      },
      "available_models": {
        "type": "list",
        "description": "允许切换的模型列表",
        "hint": "限制用户可以通过 /nai set 切换到的模型，留空则允许所有模型",
        "default": [
          "nai-diffusion-3",
          "nai-diffusion-3-furry",
          "nai-diffusion-4-full",
          "nai-diffusion-4-curated",
          "nai-diffusion-4-5-full"
        ]
      },
      "nai_size": {
        "type": "string",
        "description": "默认图片尺寸",
        "hint": "格式为 宽x高，如 832x1216（竖图）、1216x832（横图）、1024x1024（方图）",
        "default": "832x1216"
      },
      "sampler": {
        "type": "string",
        "description": "采样器",
        "hint": "默认采样方法，常用值：k_euler_ancestral、k_euler、k_dpmpp_2m 等",
        "default": "k_euler_ancestral"
      },
      "num_inference_steps": {
        "type": "int",
        "description": "推理步数",
        "hint": "生成图片的迭代步数，越高质量越好但耗时越长，推荐 23~28",
        "default": 28
      },
      "guidance_scale": {
        "type": "float",
        "description": "CFG / Guidance Scale",
        "hint": "提示词引导强度，越高越贴合提示词但可能过饱和，推荐 4.0~7.0",
        "default": 5.0
      },
      "negative_prompt_add": {
        "type": "text",
        "description": "全局附加负面提示词",
        "hint": "始终追加到负面提示词中的内容，各版本的负面提示词会叠加在此基础上",
        "default": ""
      },
      "custom_prompt_add": {
        "type": "text",
        "description": "全局附加正面提示词",
        "hint": "会拼接到每次生成的主 prompt 前面，适合放固定的质量标签",
        "default": ""
      },
      "nai_extra_params": {
        "type": "text",
        "description": "额外请求参数",
        "hint": "JSON 对象字符串，会合并到 API 请求体中，如 {\"qualityToggle\": true}",
        "default": "{}",
        "editor_mode": true,
        "editor_language": "json"
      },
      "artist_presets": {
        "type": "template_list",
        "description": "全局画师预设列表",
        "hint": "各版本专属预设为空时将自动回退到此全局预设，通过 /nai art 命令切换",
        "templates": {
          "artist_preset": {
            "name": "画师预设",
            "hint": "定义一个画师风格预设，可通过 /nai art 命令切换",
            "items": {
              "name": {
                "description": "预设名称",
                "type": "string",
                "hint": "用于在列表中展示的风格名称",
                "default": ""
              },
              "description": {
                "description": "风格说明",
                "type": "string",
                "hint": "简短描述该预设的画风特点，会在预设列表中显示",
                "default": ""
              },
              "prompt": {
                "description": "画师 Prompt",
                "type": "text",
                "hint": "画师提示词，如 artist:xxx，支持权重语法 1.2::artist:name::",
                "default": ""
              },
              "negative_prompt": {
                "description": "附加负面提示词",
                "type": "text",
                "hint": "选中该预设时追加到负面提示词中的内容",
                "default": ""
              }
            }
          }
        }
      }
    }
  },
  "model_nai3": {
    "type": "object",
    "description": "NAI V3 专属配置",
    "items": {
      "nai_size": {
        "type": "string",
        "description": "V3 默认尺寸",
        "hint": "留空则使用基础配置中的值",
        "default": "832x1216"
      },
      "selfie_prompt_add": {
        "type": "text",
        "description": "自拍时补充的角色特征标签",
        "hint": "使用自拍模式时追加到 prompt 中的角色外貌描述，如 blue eyes, long hair",
        "default": ""
      },
      "sampler": {
        "type": "string",
        "description": "V3 采样器",
        "hint": "留空则使用基础配置中的值",
        "default": "k_euler_ancestral"
      },
      "num_inference_steps": {
        "type": "int",
        "description": "V3 推理步数",
        "hint": "留空则使用基础配置中的值",
        "default": 28
      },
      "guidance_scale": {
        "type": "float",
        "description": "V3 Guidance Scale",
        "hint": "留空则使用基础配置中的值",
        "default": 5.0
      },
      "default_size": {
        "type": "string",
        "description": "V3 回退尺寸",
        "hint": "当 nai_size 未设置时使用此值作为默认尺寸",
        "default": "1024x1280"
      },
      "custom_prompt_add": {
        "type": "text",
        "description": "V3 附加正面提示词",
        "hint": "仅在使用 V3 模型时追加的正面提示词",
        "default": ""
      },
      "negative_prompt_add": {
        "type": "text",
        "description": "V3 附加负面提示词",
        "hint": "仅在使用 V3 模型时追加的负面提示词",
        "default": ""
      },
      "nai_cfg": {
        "type": "float",
        "description": "V3 CFG 参数",
        "hint": "V3 专用的 cfg 参数，0 表示使用默认值",
        "default": 0.0
      },
      "nai_noise_schedule": {
        "type": "string",
        "description": "V3 噪声调度器",
        "hint": "常用值：karras、native、exponential",
        "default": "karras"
      },
      "nai_nocache": {
        "type": "int",
        "description": "V3 nocache 参数",
        "hint": "设为 1 可禁用服务端缓存，0 为使用缓存",
        "default": 0
      },
      "nai_extra_params": {
        "type": "text",
        "description": "V3 额外请求参数",
        "hint": "JSON 对象字符串，会与基础配置中的额外参数合并，V3 专属参数优先",
        "default": "{}",
        "editor_mode": true,
        "editor_language": "json"
      },
      "artist_presets": {
        "type": "template_list",
        "description": "V3 画师预设列表",
        "hint": "V3 专属画师预设，留空时自动回退到基础配置中的全局预设",
        "templates": {
          "artist_preset": {
            "name": "画师预设",
            "hint": "定义一个画师风格预设，可通过 /nai art 命令切换",
            "items": {
              "name": {
                "description": "预设名称",
                "type": "string",
                "hint": "用于在列表中展示的风格名称",
                "default": ""
              },
              "description": {
                "description": "风格说明",
                "type": "string",
                "hint": "简短描述该预设的画风特点，会在预设列表中显示",
                "default": ""
              },
              "prompt": {
                "description": "画师 Prompt",
                "type": "text",
                "hint": "画师提示词，如 artist:xxx，支持权重语法 1.2::artist:name::",
                "default": ""
              },
              "negative_prompt": {
                "description": "附加负面提示词",
                "type": "text",
                "hint": "选中该预设时追加到负面提示词中的内容",
                "default": ""
              }
            }
          }
        }
      }
    }
  },
