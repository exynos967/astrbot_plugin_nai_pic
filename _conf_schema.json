  "prompt_generator": {
    "type": "object",
    "description": "提示词生成",
    "items": {
      "provider_id": {
        "type": "string",
        "description": "提示词生成 Provider",
        "hint": "用于将自然语言转为画图标签的 LLM Provider ID，留空则跟随当前会话的 Provider",
        "default": "",
        "_special": "select_provider"
      },
      "temperature": {
        "type": "float",
        "description": "生成温度",
        "hint": "控制提示词生成的随机性，越低越稳定，推荐 0.1~0.4",
        "default": 0.2
      },
      "max_tokens": {
        "type": "int",
        "description": "最大 Tokens",
        "hint": "提示词生成允许的最大 Token 数，过小可能导致标签被截断",
        "default": 220
      },
      "output_format": {
        "type": "string",
        "description": "输出格式",
        "hint": "text：纯文本标签输出；json：结构化 JSON 输出（需模型支持）",
        "default": "text",
        "options": [
          "text",
          "json"
        ]
      },
      "selfie_appearance_policy": {
        "type": "string",
        "description": "自拍外貌策略",
        "hint": "auto：自动判断是否保留随机外貌标签；keep：始终保留；never：始终去除",
        "default": "auto",
        "options": [
          "auto",
          "keep",
          "never"
        ]
      },
      "enforce_tag_order": {
        "type": "bool",
        "description": "标签排序",
        "hint": "开启后会对生成的提示词做轻量排序，使标签顺序更规范",
        "default": false
      },
      "prompt_template": {
        "type": "text",
        "description": "自定义提示词模板",
        "hint": "支持占位符：<<CUSTOM_SYSTEM_PROMPT>>（自定义系统提示）、<<SELFIE_HINT>>（自拍提示）、<<USER_REQUEST>>（用户输入），留空使用内置模板",
        "default": "",
        "editor_mode": true,
        "editor_language": "markdown"
      }
    }
  },
  "tagger": {
    "type": "object",
    "description": "图片打标",
    "items": {
      "provider_id": {
        "type": "string",
        "description": "打标 Provider",
        "hint": "需要支持图像输入的 Provider ID，留空则回退到提示词生成 Provider",
        "default": "",
        "_special": "select_provider"
      },
      "temperature": {
        "type": "float",
        "description": "打标温度",
        "hint": "控制打标的随机性，推荐保持较低值 0.1~0.3",
        "default": 0.2
      },
      "max_tokens": {
        "type": "int",
        "description": "打标最大 Tokens",
        "hint": "打标输出允许的最大 Token 数，图片标签较多时可适当增大",
        "default": 900
      }
    }
  },
  "admin": {
    "type": "object",
    "description": "权限管理",
    "items": {
      "admin_users": {
        "type": "list",
        "description": "插件管理员列表",
        "hint": "额外的插件管理员用户 ID，AstrBot 全局管理员自动拥有权限",
        "default": []
      },
      "default_admin_mode": {
        "type": "bool",
        "description": "默认管理员模式",
        "hint": "开启后新会话默认只有管理员可以使用生图命令，可通过 /nai st|sp 临时切换",
        "default": false
      }
    }
  },
  "auto_recall": {
    "type": "object",
    "description": "自动撤回",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "默认启用自动撤回",
        "hint": "开启后本插件发送的图片会在指定时间后自动撤回，可通过 /nai on|off 临时切换",
        "default": false
      },
      "delay_seconds": {
        "type": "int",
        "description": "撤回延迟秒数",
        "hint": "图片发出后等待多少秒再撤回，建议 3~30 秒",
        "default": 5
      },
      "allowed_groups": {
        "type": "list",
        "description": "撤回白名单",
        "hint": "仅允许这些会话启用自动撤回，格式如 aiocqhttp:123456，留空则不限制",
        "default": []
      }
    }
  },
  "nsfw_filter": {
    "type": "object",
    "description": "NSFW 过滤",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "默认启用 NSFW 过滤",
        "hint": "开启后会将过滤标签追加到负面提示词中，可通过 /nai nsfw on|off 临时切换",
        "default": false
      },
      "filter_tags": {
        "type": "string",
        "description": "过滤标签",
