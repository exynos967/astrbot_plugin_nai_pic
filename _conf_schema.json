  "prompt_generator": {
    "type": "object",
    "description": "自然语言转提示词配置",
    "items": {
      "provider_id": {
        "type": "string",
        "description": "用于提示词生成的 provider ID，留空则跟随当前会话",
        "default": "",
        "_special": "select_provider"
      },
      "temperature": {
        "type": "float",
        "description": "提示词生成温度",
        "default": 0.2
      },
      "max_tokens": {
        "type": "int",
        "description": "提示词生成最大 tokens",
        "default": 220
      },
      "output_format": {
        "type": "string",
        "description": "提示词输出格式",
        "default": "text",
        "options": [
          "text",
          "json"
        ]
      },
      "selfie_appearance_policy": {
        "type": "string",
        "description": "自拍时对随机外貌标签的处理策略",
        "default": "auto",
        "options": [
          "auto",
          "keep",
          "never"
        ]
      },
      "enforce_tag_order": {
        "type": "bool",
        "description": "对提示词做轻量排序",
        "default": false
      },
      "prompt_template": {
        "type": "text",
        "description": "自定义提示词模板，支持 <<CUSTOM_SYSTEM_PROMPT>>、<<SELFIE_HINT>>、<<USER_REQUEST>> 占位符",
        "default": "",
        "editor_mode": true,
        "editor_language": "markdown"
      }
    }
  },
  "tagger": {
    "type": "object",
    "description": "图片打标配置",
    "items": {
      "provider_id": {
        "type": "string",
        "description": "打标使用的支持图像输入的 provider ID，留空则回退到提示词 provider",
        "default": "",
        "_special": "select_provider"
      },
      "temperature": {
        "type": "float",
        "description": "打标温度",
        "default": 0.2
      },
      "max_tokens": {
        "type": "int",
        "description": "打标最大 tokens",
        "default": 900
      }
    }
  },
  "admin": {
    "type": "object",
    "description": "插件管理员配置",
    "items": {
      "admin_users": {
        "type": "list",
        "description": "额外的插件管理员用户 ID 列表",
        "default": []
      },
      "default_admin_mode": {
        "type": "bool",
        "description": "会话默认是否启用插件管理员模式",
        "default": false
      }
    }
  },
  "auto_recall": {
    "type": "object",
    "description": "图片自动撤回配置（仅 aiocqhttp / NapCat）",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "默认是否启用自动撤回",
        "default": false
      },
      "delay_seconds": {
        "type": "int",
        "description": "自动撤回延迟秒数",
        "default": 5
      },
      "allowed_groups": {
        "type": "list",
        "description": "允许自动撤回的会话白名单，格式如 aiocqhttp:123456",
        "default": []
      }
    }
  },
  "nsfw_filter": {
    "type": "object",
    "description": "NSFW 过滤配置",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "默认是否启用 NSFW 过滤",
        "default": false
      },
      "filter_tags": {
        "type": "string",
        "description": "追加到负面提示词中的过滤标签",
        "default": "{{{{{nsfw}}}}}"
      }
    }
  },
  "prompt_show": {
    "type": "object",
    "description": "提示词显示配置",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "默认是否展示最终提示词",
        "default": false
      },
      "hide_selfie_prompt_add": {
        "type": "bool",
        "description": "自拍时展示提示词是否隐藏配置中的自拍补充标签",
        "default": false
      }
    }
  },
  "custom_prompt": {
    "type": "object",
    "description": "自定义系统提示词",
    "items": {
      "system_prompt": {
        "type": "text",
        "description": "会插入到提示词生成模板最前方的自定义系统提示",
        "default": "",
        "editor_mode": true,
        "editor_language": "markdown"
      }
    }
  },
  "components": {
    "type": "object",
    "description": "调试辅助开关",
    "items": {
      "enable_debug_info": {
        "type": "bool",
        "description": "在部分流程中发送更明显的过程提示",
        "default": false
      }
    }
  }
}
